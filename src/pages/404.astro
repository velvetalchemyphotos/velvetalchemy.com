---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found | Velvet Alchemy Photography">
  <div class="min-h-screen flex flex-col items-center justify-center bg-cream text-center px-6">
    <h1 class="font-fjalla text-6xl md:text-8xl uppercase text-dark-brown mb-6">404</h1>
    <p class="font-lato text-xl text-dark-brown/70 mb-8">This page doesn't exist yet.</p>
    <a
      href="/"
      class="font-montserrat text-sm uppercase tracking-wide bg-dark-brown text-white px-8 py-3 rounded-[50px] hover:opacity-80 transition-opacity"
    >
      Back to Home
    </a>
  </div>
</BaseLayout>
