---
import { Image } from 'astro:assets';
import aboutFrame from '../assets/images/about-frame.jpg';
import aboutHeadshot from '../assets/images/about-headshot.jpg';
---
<section class="bg-white py-16 md:py-24 px-6 md:px-24 overflow-hidden">
  <div class="flex flex-col md:flex-row items-center gap-12 md:gap-20 max-w-6xl mx-auto">
    <!-- Images -->
    <div class="relative w-full md:w-1/2 min-h-[350px] md:min-h-[550px]" data-animate="slide-left">
      <div class="relative">
        <Image
          src={aboutFrame}
          alt="Decorative frame"
          width={526}
          height={400}
          class="w-full md:w-[526px] rounded-sm"
        />
        <Image
          src={aboutHeadshot}
          alt="Beth, Las Vegas fine art wedding photographer and founder of Velvet Alchemy"
          width={467}
          height={500}
          class="absolute top-0 left-4 md:left-8 w-[85%] md:w-[467px] rounded-sm shadow-lg"
        />
      </div>
    </div>

    <!-- Text -->
    <div class="w-full md:w-1/2" data-animate="fade">
      <h2 class="font-slight text-5xl md:text-[80px] leading-[1.5] text-dark-brown mb-6">
        Hey, call me B.
      </h2>

      <p class="font-lato font-light text-lg leading-[1.8] text-dark-brown mb-6">
        My name is Beth. I absolutely love to capture the chemistry on a golden desert day. My favorite type of images are those that are non-posed, natural, and reflect the vibe of those I'm photographing. I'm often approached for my creative and easy-going style.
      </p>

      <p class="font-lato font-light text-lg leading-[1.8] text-dark-brown mb-8">
        I've been told I'm pretty stellar. I can't wait to meet you.
      </p>

      <a
        href="/about"
        class="inline-block font-montserrat text-sm uppercase tracking-wide bg-dark-brown text-white px-8 py-3 rounded-[50px] hover:opacity-70 transition-opacity"
      >
        click here 4 more about me &lt;3
      </a>
    </div>
  </div>
</section>
