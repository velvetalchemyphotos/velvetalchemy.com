---
import { Image } from 'astro:assets';
import processFilm from '../assets/images/process-film.jpg';
---
<section class="relative overflow-visible min-h-[600px] md:min-h-[1000px] md:-mt-[200px] z-20">
  <!-- Black background — starts 200px from top to allow hero to show through -->
  <div class="hidden md:block absolute left-0 right-0 top-[200px] bottom-0 bg-black"></div>
  <div class="md:hidden absolute inset-0 bg-black"></div>

  <div class="relative w-full min-h-[600px] md:min-h-[1000px] max-w-[1200px] mx-auto">

    <!-- Film-strip wedding photo — large, left-aligned, ~70% width -->
    <div class="relative md:absolute md:left-[4%] md:top-0 z-30 w-full md:w-[70%]" data-animate="fade">
      <div class="relative bg-[#1a1a18]">
        <!-- Film strip top border -->
        <div class="flex items-center justify-between px-4 py-1 bg-[#1a1a18] text-[#8a8a7a] font-mono text-[10px] tracking-wider">
          <div class="flex items-center gap-6">
            <span>49</span>
            <span class="text-[8px]">▶</span>
            <span class="uppercase tracking-widest">Kodak Portra 400BW</span>
          </div>
          <div class="flex items-center gap-6">
            <span>50</span>
            <span class="text-[8px]">▶</span>
            <span class="uppercase tracking-widest">Kodak Por</span>
          </div>
        </div>
        <!-- Photo -->
        <div class="border-x-[3px] border-[#1a1a18]">
          <Image
            src={processFilm}
            alt="Fine art 35mm film wedding photo"
            width={1000}
            height={665}
            class="w-full h-auto object-cover"
          />
        </div>
        <!-- Film strip bottom border -->
        <div class="flex items-center px-4 py-1 bg-[#1a1a18] text-[#8a8a7a] font-mono text-[10px]">
          <span class="text-[8px]">▶</span>
          <span class="ml-4">8</span>
        </div>
      </div>
    </div>

    <!-- "MY VOWS TO YOU" text — two overlapping rotated layers -->
    <!-- Back layer — deep red -->
    <div class="hidden md:block absolute z-40" style="top: 230px; left: 68%; transform: rotate(90deg); transform-origin: top left;">
      <p class="font-fjalla uppercase text-[154px] leading-[0.85] tracking-tight whitespace-nowrap" style="color: rgb(173, 17, 0);">
        MY VOWS
      </p>
      <p class="font-fjalla uppercase text-[154px] leading-[0.85] tracking-tight whitespace-nowrap" style="color: rgb(173, 17, 0);">
        TO YOU
      </p>
    </div>
    <!-- Front layer — bright red -->
    <div class="hidden md:block absolute z-40" style="top: 230px; left: 88%; transform: rotate(90deg); transform-origin: top left;">
      <p class="font-fjalla uppercase text-[154px] leading-[0.85] tracking-tight whitespace-nowrap" style="color: rgb(255, 25, 0);">
        MY VOWS
      </p>
      <p class="font-fjalla uppercase text-[154px] leading-[0.85] tracking-tight whitespace-nowrap" style="color: rgb(255, 25, 0);">
        TO YOU
      </p>
    </div>

    <!-- Mobile: show text normally -->
    <div class="md:hidden text-center py-8">
      <span class="text-bright-red font-fjalla uppercase text-5xl leading-none">MY VOWS TO YOU</span>
    </div>

    <!-- Promise text — left-aligned below image -->
    <div class="relative md:absolute md:bottom-12 md:left-[4%] z-20 px-6 md:px-0 pb-12 md:pb-0 md:w-[55%] mt-8 md:mt-0">
      <p class="font-oswald font-light text-base md:text-lg text-coral-light leading-relaxed mb-1">
        A safe and inclusive environment for all
      </p>
      <div class="w-full h-px bg-coral-light/40 mb-3"></div>

      <p class="font-oswald font-light text-base md:text-lg text-coral-light leading-relaxed mb-1">
        True excitement for all of the events of your beautiful day
      </p>
      <div class="w-full h-px bg-coral-light/40 mb-3"></div>

      <p class="font-oswald font-light text-base md:text-lg text-coral-light leading-relaxed mb-1">
        Guidance & support if you feel awkward in front of my lens
      </p>
      <div class="w-full h-px bg-coral-light/40 mb-3"></div>

      <p class="font-oswald font-light text-base md:text-lg text-coral-light leading-relaxed mb-8">
        I promise to work with the characteristics that make you, you
      </p>

      <div class="text-center">
        <a
          href="/experience-process"
          class="inline-block font-montserrat text-sm tracking-wide text-coral-light border border-coral-light/60 px-10 py-3 rounded-[50px] hover:bg-coral-light/10 transition-colors"
        >
          what it's like to work with me
        </a>
      </div>
    </div>
  </div>
</section>
