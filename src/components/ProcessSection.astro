---
import { Image } from 'astro:assets';
import processFilm from '../assets/images/process-film.jpg';
---
<section class="relative bg-black overflow-hidden min-h-[600px] md:min-h-[900px]">
  <div class="relative w-full min-h-[600px] md:min-h-[900px]">

    <!-- Film-strip wedding photo with polaroid/film border -->
    <div class="relative md:absolute md:left-[5%] md:top-0 z-10 w-full md:w-[60%]" data-animate="fade">
      <div class="relative bg-[#1a1a18]">
        <!-- Film strip top border -->
        <div class="flex items-center justify-between px-4 py-1 bg-[#1a1a18] text-[#8a8a7a] font-mono text-[10px] tracking-wider">
          <div class="flex items-center gap-6">
            <span>49</span>
            <span class="text-[8px]">▶</span>
            <span class="uppercase tracking-widest">Kodak Portra 400BW</span>
          </div>
          <div class="flex items-center gap-6">
            <span>50</span>
            <span class="text-[8px]">▶</span>
            <span class="uppercase tracking-widest">Kodak Por</span>
          </div>
        </div>
        <!-- Photo -->
        <div class="border-x-[3px] border-[#1a1a18]">
          <Image
            src={processFilm}
            alt="Fine art 35mm film wedding photo"
            width={1000}
            height={665}
            class="w-full h-auto object-cover"
          />
        </div>
        <!-- Film strip bottom border -->
        <div class="flex items-center px-4 py-1 bg-[#1a1a18] text-[#8a8a7a] font-mono text-[10px]">
          <span class="text-[8px]">▶</span>
          <span class="ml-4">8</span>
        </div>
      </div>
    </div>

    <!-- Huge rotated "MY VOWS TO YOU" text — right side, duplicated/layered effect -->
    <div class="hidden md:flex absolute right-0 top-0 bottom-0 w-[45%] items-center justify-center overflow-hidden">
      <!-- Back layer — deep red -->
      <div class="absolute text-deep-red font-fjalla uppercase leading-[0.85] text-[180px] tracking-tight" style="writing-mode: vertical-rl; text-orientation: mixed; transform: translate(15px, 10px);">
        MY VOWS TO YOU
      </div>
      <!-- Front layer — bright red -->
      <div class="text-bright-red font-fjalla uppercase leading-[0.85] text-[180px] tracking-tight" style="writing-mode: vertical-rl; text-orientation: mixed;">
        MY VOWS TO YOU
      </div>
    </div>

    <!-- Mobile: show text normally -->
    <div class="md:hidden text-center py-8">
      <span class="text-bright-red font-fjalla uppercase text-5xl leading-none">MY VOWS TO YOU</span>
    </div>

    <!-- Promise text — bottom left, with spacing from film image -->
    <div class="relative md:absolute md:bottom-12 md:left-[5%] z-20 px-6 md:px-0 pb-12 md:pb-0 md:w-[45%] mt-8 md:mt-0">
      <p class="font-oswald font-light text-base md:text-lg text-coral-light leading-relaxed mb-1">
        A safe and inclusive environment for all
      </p>
      <div class="w-full h-px bg-coral-light/40 mb-3"></div>

      <p class="font-oswald font-light text-base md:text-lg text-coral-light leading-relaxed mb-1">
        True excitement for all of the events of your beautiful day
      </p>
      <div class="w-full h-px bg-coral-light/40 mb-3"></div>

      <p class="font-oswald font-light text-base md:text-lg text-coral-light leading-relaxed mb-1">
        Guidance & support if you feel awkward in front of my lens
      </p>
      <div class="w-full h-px bg-coral-light/40 mb-3"></div>

      <p class="font-oswald font-light text-base md:text-lg text-coral-light leading-relaxed mb-8">
        I promise to work with the characteristics that make you, you
      </p>

      <div class="text-center">
        <a
          href="/experience-process"
          class="inline-block font-montserrat text-sm tracking-wide text-coral-light border border-coral-light/60 px-10 py-3 rounded-[50px] hover:bg-coral-light/10 transition-colors"
        >
          what it's like to work with me
        </a>
      </div>
    </div>
  </div>
</section>
