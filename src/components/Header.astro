---
import { Image } from 'astro:assets';
import logo from '../assets/images/logo.png';

const leftLinks = [
  { label: 'About', href: '/about' },
  { label: 'Experience', href: '/experience-process' },
  { label: 'Pricing', href: '/pricing' },
];

const rightLinks = [
  { label: 'FAQs', href: '/faqs' },
  { label: 'Recent Work', href: '/recent-work' },
  { label: 'Contact', href: '/contact' },
];

const allLinks = [...leftLinks, ...rightLinks];
---
<header class="absolute top-0 left-0 w-full z-50">
  <div class="hidden md:flex items-start justify-between py-4 px-8 max-w-[1200px] mx-auto">
    <!-- Left nav links -->
    <nav class="flex items-center gap-10">
      {leftLinks.map(link => (
        <a
          href={link.href}
          class="font-fjalla text-[30px] uppercase text-dark-brown hover:opacity-80 transition-opacity"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Centered Logo -->
    <a href="/" class="shrink-0 mx-8">
      <Image
        src={logo}
        alt="Velvet Alchemy Photography logo"
        width={295}
        height={74}
        class="h-[74px] w-auto object-contain"
        loading="eager"
      />
    </a>

    <!-- Right nav links -->
    <nav class="flex items-center gap-10">
      {rightLinks.map(link => (
        <a
          href={link.href}
          class="font-fjalla text-[30px] uppercase text-dark-brown hover:opacity-80 transition-opacity"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>

  <!-- Mobile Header -->
  <div class="flex md:hidden items-center justify-between px-4 py-3">
    <a href="/" class="shrink-0">
      <Image
        src={logo}
        alt="Velvet Alchemy Photography logo"
        width={100}
        height={100}
        class="h-12 w-auto object-contain"
        loading="eager"
      />
    </a>
    <button
      id="mobile-menu-btn"
      class="flex flex-col gap-1.5 p-2"
      aria-label="Toggle menu"
    >
      <span class="block w-6 h-0.5 bg-dark-brown transition-transform"></span>
      <span class="block w-6 h-0.5 bg-dark-brown transition-opacity"></span>
      <span class="block w-6 h-0.5 bg-dark-brown transition-transform"></span>
    </button>
  </div>

  <!-- Mobile Dropdown -->
  <nav
    id="mobile-menu"
    class="hidden md:hidden absolute right-4 top-full w-[155px] bg-dark-brown text-white py-8 px-6 flex-col gap-4"
    style="border-radius: 0 0 77.5px 77.5px;"
  >
    {allLinks.map(link => (
      <a
        href={link.href}
        class="block font-montserrat text-xs uppercase tracking-widest text-white/80 hover:text-white transition-colors py-2"
      >
        {link.label}
      </a>
    ))}
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    if (isOpen) {
      menu?.classList.add('hidden');
      menu?.classList.remove('flex');
    } else {
      menu?.classList.remove('hidden');
      menu?.classList.add('flex');
    }
  });
</script>
