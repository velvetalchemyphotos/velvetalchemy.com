---
const leftLinks = [
  { label: 'Recent Work', href: '/recent-work' },
  { label: 'About', href: '/about' },
  { label: 'Experience', href: '/experience-process' },
];

const rightLinks = [
  { label: 'Pricing', href: '/pricing' },
  { label: 'FAQs', href: '/faqs' },
  { label: 'Contact', href: '/contact' },
];
---
<footer class="bg-black py-12 md:py-16 px-6">
  <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center md:items-start justify-between gap-8">
    <!-- Left nav -->
    <nav class="flex flex-col gap-2 text-center md:text-left">
      {leftLinks.map(link => (
        <a
          href={link.href}
          class="font-fjalla text-sm md:text-base uppercase text-coral-light hover:text-coral transition-colors"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Center brand -->
    <div class="text-center">
      <h2 class="font-mergian-slant text-3xl md:text-[40px] text-coral-light italic">
        Velvet Alchemy<br />Photos
      </h2>
    </div>

    <!-- Right nav -->
    <nav class="flex flex-col gap-2 text-center md:text-right">
      {rightLinks.map(link => (
        <a
          href={link.href}
          class="font-fjalla text-sm md:text-base uppercase text-coral-light hover:text-coral transition-colors"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</footer>
