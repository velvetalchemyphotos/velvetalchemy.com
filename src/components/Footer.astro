---
const navLinks = [
  { label: 'Contact', href: '/contact' },
  { label: 'About', href: '/about' },
  { label: 'Recent Work', href: '/recent-work' },
  { label: 'Experience', href: '/experience-process' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'FAQs', href: '/faqs' },
];
---
<footer class="bg-black py-12 md:py-16 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="font-mergian text-2xl md:text-[30px] text-coral-light mb-8">
      VelvetAlchemy Photos
    </h2>
    <nav class="flex flex-wrap items-center justify-center gap-4 md:gap-6">
      {navLinks.map(link => (
        <a
          href={link.href}
          class="font-montserrat text-xs uppercase tracking-widest text-coral/70 hover:text-coral transition-colors"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</footer>
