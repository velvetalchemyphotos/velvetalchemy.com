---
import { Image } from 'astro:assets';
import filmImg from '../assets/images/pricing/film.jpg';
import digitalImg from '../assets/images/pricing/digital.jpg';
import filmDigitalImg from '../assets/images/pricing/film-digital.jpg';

const cards = [
  { label: 'film', href: '/pricing#film', image: filmImg, alt: "Nat and Glenn's 35mm film wedding gallery preview" },
  { label: 'digital', href: '/pricing#digital', image: digitalImg, alt: 'Matthew and Yanqin wedding sneak peek' },
  { label: 'film & digital', href: '/pricing#filmdigital', image: filmDigitalImg, alt: 'Dayse and Fredi wedding sneak peek' },
];
---
<section class="bg-black py-16 md:py-24 px-6 md:px-24" data-animate="fade">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-[1200px] mx-auto">
    {cards.map(card => (
      <a href={card.href} class="group block">
        <div class="overflow-hidden rounded-sm mb-4">
          <Image
            src={card.image}
            alt={card.alt}
            width={400}
            height={550}
            class="w-full h-[400px] md:h-[500px] object-cover transition-transform duration-300 group-hover:scale-105"
          />
        </div>
        <div class="text-center">
          <span class="inline-block font-fjalla text-lg md:text-xl tracking-wide text-white border border-white/40 px-10 py-2 rounded-[50px] group-hover:border-white/70 transition-colors">
            {card.label}
          </span>
        </div>
      </a>
    ))}
  </div>
</section>
