<section class="bg-cream-light py-12 md:py-16 px-6 text-center">
  <div class="max-w-4xl mx-auto">
    <p class="font-oswald font-light text-sm uppercase tracking-[0.2em] text-dark-brown/60 mb-4">
      Follow along
    </p>
    <a
      href="https://www.instagram.com/velvetalchemy/"
      target="_blank"
      rel="noopener noreferrer"
      class="font-slight text-3xl md:text-4xl text-coral hover:text-deep-red transition-colors"
    >
      @velvetalchemy
    </a>
    <!-- Placeholder grid for future Instagram integration -->
    <div class="grid grid-cols-3 md:grid-cols-6 gap-2 mt-8 max-w-3xl mx-auto">
      {Array.from({ length: 6 }).map(() => (
        <div class="aspect-square bg-dark-brown/5 rounded-sm"></div>
      ))}
    </div>
  </div>
</section>
