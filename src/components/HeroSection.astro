---
import { Image } from 'astro:assets';
import heroBg from '../assets/images/hero-bg.jpg';
import gallery1 from '../assets/images/hero/gallery-1.jpg';
import gallery2 from '../assets/images/hero/gallery-2.jpg';
import gallery3 from '../assets/images/hero/gallery-3.jpg';
---
<section class="relative w-full overflow-hidden" style="min-height: 600px;">
  <!-- Background image with 90% opacity -->
  <div class="absolute inset-0">
    <Image
      src={heroBg}
      alt="Wedding photography background"
      width={1200}
      height={800}
      class="w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-white/10"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col md:flex-row items-center justify-between px-6 md:px-24 py-16 md:py-32 min-h-[600px] md:min-h-[800px]">
    <!-- Heading -->
    <div class="max-w-xl mb-12 md:mb-0" data-animate="slide-left">
      <h1
        class="font-fjalla text-4xl md:text-[102px] uppercase leading-none"
        style="text-shadow: 2px 2px 5px rgba(0,0,0,0.36);"
      >
        Contrast & dreamy pastels in full motley
      </h1>
    </div>

    <!-- Carousel -->
    <div class="relative w-[200px] h-[310px] md:w-[423px] md:h-[658px] rounded-full overflow-hidden shrink-0">
      <div id="hero-carousel" class="relative w-full h-full">
        <Image
          src={gallery1}
          alt="Brittany + Stephen Gallery"
          width={423}
          height={658}
          class="hero-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-100"
          loading="eager"
          data-index="0"
        />
        <Image
          src={gallery2}
          alt="Wedding photography"
          width={423}
          height={658}
          class="hero-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-0"
          loading="eager"
          data-index="1"
        />
        <Image
          src={gallery3}
          alt="Wedding photography"
          width={423}
          height={658}
          class="hero-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-0"
          loading="eager"
          data-index="2"
        />
      </div>
      <!-- Carousel nav dots -->
      <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-10">
        <button class="hero-dot w-2 h-2 rounded-full bg-white transition-opacity opacity-100" data-index="0" aria-label="Slide 1"></button>
        <button class="hero-dot w-2 h-2 rounded-full bg-white transition-opacity opacity-50" data-index="1" aria-label="Slide 2"></button>
        <button class="hero-dot w-2 h-2 rounded-full bg-white transition-opacity opacity-50" data-index="2" aria-label="Slide 3"></button>
      </div>
    </div>
  </div>
</section>

<script>
  let currentSlide = 0;
  const slides = document.querySelectorAll('.hero-slide');
  const dots = document.querySelectorAll('.hero-dot');

  function goToSlide(index: number) {
    slides.forEach((slide, i) => {
      (slide as HTMLElement).style.opacity = i === index ? '1' : '0';
    });
    dots.forEach((dot, i) => {
      (dot as HTMLElement).style.opacity = i === index ? '1' : '0.5';
    });
    currentSlide = index;
  }

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const index = parseInt((dot as HTMLElement).dataset.index || '0');
      goToSlide(index);
    });
  });

  // Auto-advance every 5 seconds
  setInterval(() => {
    goToSlide((currentSlide + 1) % slides.length);
  }, 5000);
</script>
