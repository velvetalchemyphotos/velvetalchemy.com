---
import { Image } from 'astro:assets';
import heroBg from '../assets/images/hero-bg.jpg';
import gallery1 from '../assets/images/hero/gallery-1.jpg';
import gallery2 from '../assets/images/hero/gallery-2.jpg';
import gallery3 from '../assets/images/hero/gallery-3.jpg';
---
<section class="relative w-full overflow-hidden min-h-[500px] md:min-h-[1003px]">
  <!-- Background image — static, wider than viewport -->
  <div class="absolute inset-0 overflow-hidden">
    <Image
      src={heroBg}
      alt="Wedding photography background"
      width={1600}
      height={1071}
      class="w-[145%] h-full object-cover object-[center_0%]"
      loading="eager"
    />
  </div>

  <!-- Mobile layout -->
  <div class="relative z-10 flex flex-col items-center pt-28 pb-16 gap-8 md:hidden px-6 min-h-[500px]">
    <h1
      class="font-fjalla text-4xl leading-none text-black text-center"
      style="text-shadow: 2px 2px 5px rgba(0,0,0,0.36);"
    >
      Contrast &<br />dreamy pastels<br />in full motley
    </h1>
    <div class="relative w-[200px] h-[310px] rounded-[50%] overflow-hidden">
      <div class="hero-carousel relative w-full h-full">
        <Image
          src={gallery1}
          alt="Brittany + Stephen Gallery"
          width={423}
          height={658}
          class="hero-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-100"
          loading="eager"
          data-index="0"
        />
        <Image
          src={gallery2}
          alt="Wedding photography"
          width={423}
          height={658}
          class="hero-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-0"
          loading="eager"
          data-index="1"
        />
        <Image
          src={gallery3}
          alt="Wedding photography"
          width={423}
          height={658}
          class="hero-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-0"
          loading="eager"
          data-index="2"
        />
      </div>
    </div>
  </div>

  <!-- Desktop layout — absolute positioned elements -->
  <div class="relative z-10 hidden md:block min-h-[1003px]">
    <!-- Heading — center-left, right-aligned text -->
    <div class="absolute inset-0 flex items-center z-10 max-w-[1200px] mx-auto left-0 right-0" data-animate="slide-left">
      <div class="w-[625px] ml-[8%]">
        <h1
          class="font-fjalla text-[102px] leading-none text-black text-right"
          style="text-shadow: 2px 2px 5px rgba(0,0,0,0.36);"
        >
          Contrast &<br />dreamy pastels<br />in full motley
        </h1>
      </div>
    </div>

    <!-- Carousel — right side, overlapping with heading -->
    <div class="absolute right-0 left-0 mx-auto max-w-[1200px] top-0 bottom-0 pointer-events-none">
      <div class="absolute right-[5%] top-[65%] -translate-y-1/2 w-[423px] h-[658px] rounded-[50%] overflow-hidden pointer-events-auto">
      <div class="hero-carousel relative w-full h-full">
        <Image
          src={gallery1}
          alt="Brittany + Stephen Gallery"
          width={423}
          height={658}
          class="hero-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-100"
          loading="eager"
          data-index="0"
        />
        <Image
          src={gallery2}
          alt="Wedding photography"
          width={423}
          height={658}
          class="hero-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-0"
          loading="eager"
          data-index="1"
        />
        <Image
          src={gallery3}
          alt="Wedding photography"
          width={423}
          height={658}
          class="hero-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-0"
          loading="eager"
          data-index="2"
        />
      </div>
      <!-- Carousel nav dots -->
      <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 z-10">
        <button class="hero-dot w-2 h-2 rounded-full bg-white transition-opacity opacity-100" data-index="0" aria-label="Slide 1"></button>
        <button class="hero-dot w-2 h-2 rounded-full bg-white transition-opacity opacity-50" data-index="1" aria-label="Slide 2"></button>
        <button class="hero-dot w-2 h-2 rounded-full bg-white transition-opacity opacity-50" data-index="2" aria-label="Slide 3"></button>
      </div>
    </div>
    </div>
  </div>
</section>

<script>
  // Hero image carousel — uses data-index to sync mobile + desktop slides
  let currentSlide = 0;
  const totalSlides = 3;
  const slides = document.querySelectorAll('.hero-slide');
  const dots = document.querySelectorAll('.hero-dot');

  function goToSlide(index: number) {
    slides.forEach(slide => {
      const slideIndex = parseInt((slide as HTMLElement).dataset.index || '0');
      (slide as HTMLElement).style.opacity = slideIndex === index ? '1' : '0';
    });
    dots.forEach(dot => {
      const dotIndex = parseInt((dot as HTMLElement).dataset.index || '0');
      (dot as HTMLElement).style.opacity = dotIndex === index ? '1' : '0.5';
    });
    currentSlide = index;
  }

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const index = parseInt((dot as HTMLElement).dataset.index || '0');
      goToSlide(index);
    });
  });

  setInterval(() => {
    goToSlide((currentSlide + 1) % totalSlides);
  }, 5000);
</script>
