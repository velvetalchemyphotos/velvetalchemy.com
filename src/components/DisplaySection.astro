---
import { Image } from 'astro:assets';
import portfolioBg from '../assets/images/portfolio-bg.jpg';
---
<section class="relative overflow-hidden" style="min-height: 400px;">
  <!-- Background image with 70% opacity -->
  <div class="absolute inset-0">
    <Image
      src={portfolioBg}
      alt="Wedding photography"
      width={1200}
      height={800}
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/30"></div>
  </div>

  <!-- Typographic display -->
  <div class="relative z-10 flex flex-col items-center justify-center min-h-[400px] md:min-h-[570px] px-6 text-center">
    <span class="font-fjalla text-5xl md:text-[120px] uppercase leading-none text-coral-light block mb-2" data-animate="slide-left">
      GROOM
    </span>
    <span class="font-fjalla text-5xl md:text-[120px] uppercase leading-none text-slate-blue block mb-2" data-animate="slide-right">
      BRIDE
    </span>
    <span class="font-fjalla text-6xl md:text-[140px] uppercase leading-none text-coral-light font-bold" data-animate="fade">
      2
    </span>
  </div>
</section>
